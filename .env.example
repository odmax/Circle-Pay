# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/circle-pay?schema=public"

# NextAuth
AUTH_SECRET="" # Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# PayFast (South Africa payments)
PAYFAST_MERCHANT_ID=""
PAYFAST_MERCHANT_KEY=""
PAYFAST_PASSPHRASE=""
PAYFAST_SANDBOX=true

# Owner Admin
# Case-insensitive comparison. Must be set for owner features.
# Changing OWNER_EMAIL does NOT automatically demote the previous owner.
# The primary owner receives:
#   - InternalAdmin SUPER_ADMIN role on register/login
#   - owner-unlimited plan (hidden from public pricing, unlimited circles)
OWNER_EMAIL="admin@mozetech.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
