// ─── Wallet & Ledger ──────────────────────────────────────
//
// DESIGN RULES:
// 1. LedgerEntry is IMMUTABLE — never UPDATE or DELETE
// 2. LedgerAccount has NO stored balance — always computed from entries
// 3. Reversals = new LedgerTransaction + new LedgerEntries (never edit originals)
// 4. Balance = SUM(CREDIT) - SUM(DEBIT) for each account, computed at read time

enum WalletType {
  USER_WALLET
  CIRCLE_WALLET
  PLATFORM_HOLDING
  PROVIDER_HOLDING
}

enum WalletStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum LedgerAccountType {
  CONTRIBUTIONS
  PAYOUTS
  EXPENSES
  SETTLEMENTS
  FEES
  ADJUSTMENTS
  INVESTMENTS
  RETURNS
  INCOME
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

model Wallet {
  id        String       @id @default(cuid())
  circleId  String?
  userId    String?
  type      WalletType
  status    WalletStatus @default(ACTIVE)
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  circle       Circle?             @relation(fields: [circleId], references: [id])
  user         User?               @relation("WalletUser", fields: [userId], references: [id])
  accounts     LedgerAccount[]
  transactions WalletTransaction[]

  @@index([circleId])
  @@index([userId])
}

// LedgerAccount — NO balance field. Balance is computed from LedgerEntry rows.
model LedgerAccount {
  id        String            @id @default(cuid())
  walletId  String
  name      String
  type      LedgerAccountType
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  wallet  Wallet        @relation(fields: [walletId], references: [id])
  entries LedgerEntry[]

  @@index([walletId])
}

// LedgerTransaction: groups balanced entries. Sum of debits = sum of credits.
model LedgerTransaction {
  id             String   @id @default(cuid())
  circleId       String
  amount         Decimal  @db.Decimal(12, 2)
  type           String // CONTRIBUTION, PAYOUT, EXPENSE, SETTLEMENT, FEE, REVERSAL
  status         String   @default("PENDING") // PENDING, CONFIRMED, REVERSED
  idempotencyKey String?  @unique
  metadata       Json?
  createdAt      DateTime @default(now())

  circle    Circle              @relation(fields: [circleId], references: [id])
  entries   LedgerEntry[]
  walletTxs WalletTransaction[]

  @@index([circleId])
}

// LedgerEntry: IMMUTABLE. Never UPDATE or DELETE. Creates audit trail.
model LedgerEntry {
  id          String          @id @default(cuid())
  accountId   String
  txId        String
  type        LedgerEntryType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  createdAt   DateTime        @default(now())

  account     LedgerAccount     @relation(fields: [accountId], references: [id])
  transaction LedgerTransaction @relation(fields: [txId], references: [id])

  @@index([accountId])
  @@index([txId])
}

// WalletTransaction: user-facing record linked to underlying ledger
model WalletTransaction {
  id             String   @id @default(cuid())
  walletId       String
  ledgerTxId     String
  type           String // TOPUP, PAYOUT, WITHDRAWAL, TRANSFER_IN, TRANSFER_OUT
  amount         Decimal  @db.Decimal(12, 2)
  status         String   @default("PENDING") // PENDING, CONFIRMED, FAILED, CANCELLED
  description    String?
  initiatedById  String
  providerRef    String?
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())

  wallet           Wallet                  @relation(fields: [walletId], references: [id])
  ledgerTx         LedgerTransaction       @relation(fields: [ledgerTxId], references: [id])
  initiatedBy      User                    @relation("WalletTxInitiator", fields: [initiatedById], references: [id])
  approvalRequests WalletApprovalRequest[]

  @@index([walletId])
  @@index([createdAt])
}

// WalletApprovalRule: defines required approvers for wallet actions
model WalletApprovalRule {
  id                    String   @id @default(cuid())
  circleId              String
  action                String // WITHDRAWAL, PAYOUT, EXPENSE_OVER
  threshold             Decimal  @db.Decimal(12, 2)
  requiredApprovalCount Int      @default(1)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())

  circle Circle @relation(fields: [circleId], references: [id])

  @@index([circleId])
}

model WalletApprovalRequest {
  id            String   @id @default(cuid())
  circleId      String
  walletTxId    String
  requestedById String
  requiredCount Int      @default(1)
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  circle      Circle            @relation(fields: [circleId], references: [id])
  walletTx    WalletTransaction @relation(fields: [walletTxId], references: [id])
  requestedBy User              @relation("ApprovalRequester", fields: [requestedById], references: [id])
  approvals   WalletApproval[]

  @@index([circleId])
}

model WalletApproval {
  id           String   @id @default(cuid())
  requestId    String
  approvedById String
  approvedAt   DateTime @default(now())

  request    WalletApprovalRequest @relation(fields: [requestId], references: [id])
