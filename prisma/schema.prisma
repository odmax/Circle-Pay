generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  phone            String?   @unique
  passwordHash     String?
  currency         String    @default("NGN")
  isSuspended      Boolean   @default(false)
  suspendedAt      DateTime?
  suspendedById    String?
  suspensionReason String?
  settings         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  circlesCreated           Circle[]                     @relation("CircleCreator")
  accounts                 Account[]
  sessions                 Session[]
  circleMembers            CircleMember[]
  contributions            Contribution[]               @relation("ContributionPayer")
  contributionsRecorded    Contribution[]               @relation("ContributionRecorder")
  contributionPlansCreated ContributionPlan[]           @relation("ContributionPlanCreator")
  expensesPaid             Expense[]                    @relation("ExpensePayer")
  expensesCreated          Expense[]                    @relation("ExpenseCreator")
  expenseSplits            ExpenseSplit[]
  notifications            Notification[]
  invitationsSent          Invitation[]                 @relation("Inviter")
  balancesAsDebtor         Balance[]                    @relation("Debtor")
  balancesAsCreditor       Balance[]                    @relation("Creditor")
  settlementsAsDebtor      Settlement[]                 @relation("SettlementDebtor")
  settlementsAsCreditor    Settlement[]                 @relation("SettlementCreditor")
  settlementsCreated       Settlement[]                 @relation("SettlementCreator")
  settlementsConfirmed     Settlement[]                 @relation("SettlementConfirmer")
  goalsCreated             Goal[]
  goalAllocationsReceived  GoalAllocation[]             @relation("GoalAllocationReceiver")
  goalAllocationsCreated   GoalAllocation[]             @relation("GoalAllocationCreator")
  transactions             Transaction[]
  subscription             UserSubscription?
  paymentTransactions      PaymentTransaction[]
  internalAdmin            InternalAdmin?
  auditLogs                AuditLog[]
  joinRequests             JoinRequest[]                @relation("JoinRequestUser")
  joinRequestsReviewed     JoinRequest[]                @relation("JoinRequestReviewer")
  wallets                  Wallet[]                     @relation("WalletUser")
  walletTransactions       WalletTransaction[]          @relation("WalletTxInitiator")
  approvalRequests         WalletApprovalRequest[]      @relation("ApprovalRequester")
  approvalsGiven           WalletApproval[]             @relation("ApprovalApprover")
  payoutCycles             PayoutCycle[]                @relation("PayoutRecipient")
  ownerNotes               OwnerNote[]                  @relation("OwnerNoteAdmin")
  moderationReviews        CircleModerationReview[]     @relation("ModerationReviewer")
  bulkOperations           BulkOperation[]              @relation("BulkOpAdmin")
  platformSettingsUpdated  PlatformSetting[]            @relation("PlatformSettingUpdater")
  featureFlagsUpdated      FeatureFlag[]                @relation("FeatureFlagUpdater")
  promoCodesCreated        PromoCode[]                  @relation("PromoCreator")
  promoRedemptions         PromoRedemption[]            @relation("PromoUser")
  broadcastsCreated        PlatformBroadcast[]          @relation("BroadcastCreator")
  broadcastReceived        PlatformBroadcastRecipient[] @relation("BroadcastRecipient")
  supportTickets           SupportTicket[]              @relation("TicketCreator")
  supportMessages          SupportTicketMessage[]       @relation("TicketMessageSender")
  abuseReports             AbuseReport[]                @relation("AbuseReporter")
  abuseReportsReviewed     AbuseReport[]                @relation("AbuseReviewer")
  feedPosts                FeedPost[]                   @relation("FeedPostAuthor")
  feedComments             FeedComment[]                @relation("FeedCommentUser")
  feedReactions            FeedReaction[]               @relation("FeedReactionUser")
  eventsCreated            CircleEvent[]                @relation("EventCreator")
  eventRSVPs               CircleEventRSVP[]            @relation("RSVPUser")
  pollsCreated             CirclePoll[]                 @relation("PollCreator")
  pollVotes                CirclePollVote[]             @relation("PollVoter")
  verificationsReviewed    CircleVerification[]         @relation("VerificationReviewer")
  completedWorkflowSteps   CircleWorkflowStep[]         @relation("WorkflowStepCompleter")
  paymentIntents           CirclePaymentIntent[]        @relation("PaymentIntentUser")
  paymentIntentsConfirmed  CirclePaymentIntent[]        @relation("PaymentIntentConfirmer")
  projectsCreated          Project[]                    @relation("ProjectCreator")
  fundingRoundsCreated     ProjectFundingRound[]        @relation("FundingRoundCreator")
  projectContributions     ProjectContribution[]        @relation("ProjectContributor")
  projectContConfirmations ProjectContribution[]        @relation("ProjectContributionConfirmer")
  projectExpensesCreated   ProjectExpense[]             @relation("ProjectExpenseCreator")
  projectExpensesApproved  ProjectExpense[]             @relation("ProjectExpenseApprover")
  projectExpensesPaid      ProjectExpense[]             @relation("ProjectExpensePayer")
  projectAssetsCreated     ProjectAsset[]               @relation("ProjectAssetCreator")
  projectRevenuesCreated   ProjectRevenue[]             @relation("ProjectRevenueCreator")
  distributionsCreated     ProjectDistribution[]        @relation("DistributionCreator")
  distributionsApproved    ProjectDistribution[]        @relation("DistributionApprover")
  distributionItems        ProjectDistributionItem[]    @relation("DistributionRecipient")
  legalAcceptances         UserLegalAcceptance[]
  mobileSessions           MobileSession[]
  mobilePushTokens         MobilePushToken[]
  univApprovalRequests     ApprovalRequest[]            @relation("UnivApprovalRequester")
  univApprovalDecisions    ApprovalRequestDecision[]    @relation("UnivApprovalReviewer")
  receiptsIssuedTo         FinancialReceipt[]           @relation("ReceiptIssuedTo")
  receiptsIssuedBy         FinancialReceipt[]           @relation("ReceiptIssuedBy")
  receiptsVoidedBy         FinancialReceipt[]           @relation("ReceiptVoidedBy")
  workflowsCreated         ApprovalWorkflow[]           @relation("WorkflowCreator")
  workflowsUpdated         ApprovalWorkflow[]           @relation("WorkflowUpdater")

  @@index([email])
}

// ─── Mobile Sessions ──────────────────────────────────────

model MobileSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  deviceName String?
  deviceId   String?
  platform   String?
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([tokenHash])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @unique
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ───────────────────────────────────────────

enum CircleType {
  FAMILY
  TRAVEL
  HOUSEMATE
  WEDDING
  SAVINGS
  STOKVEL
  CHURCH
  INVESTMENT
  CUSTOM
}

enum CircleVisibility {
  PRIVATE
  INVITE_ONLY
  PUBLIC
}

enum MemberRole {
  OWNER
  ADMIN
  TREASURER
  MEMBER
  VIEWER
}

model Circle {
  id                   String           @id @default(cuid())
  name                 String
  description          String?
  currency             String           @default("NGN")
  type                 CircleType       @default(CUSTOM)
  visibility           CircleVisibility @default(PRIVATE)
  inviteCode           String           @unique @default(cuid())
  inviteCodeEnabled    Boolean          @default(true)
  inviteCodeExpiresAt  DateTime?
  isActive             Boolean          @default(true)
  deletedAt            DateTime?
  country              String?
  city                 String?
  publicDescription    String?
  rules                String?
  joinApprovalRequired Boolean          @default(true)
  isFeatured           Boolean          @default(false)
  featuredAt           DateTime?
  featuredById         String?
  settings             Json?
  createdById          String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  createdBy              User                     @relation("CircleCreator", fields: [createdById], references: [id])
  members                CircleMember[]
  contributions          Contribution[]
  contributionPlans      ContributionPlan[]
  goals                  Goal[]
  goalAllocations        GoalAllocation[]
  expenses               Expense[]
  balances               Balance[]
  settlements            Settlement[]
  transactions           Transaction[]
  notifications          Notification[]
  invitations            Invitation[]
  auditLogs              AuditLog[]               @relation("AuditLogCircle")
  aiInsights             AIInsight[]              @relation("AIInsightCircle")
  automationLogs         CircleAutomationLog[]
  widgets                CircleWidget[]
  expenseCategories      ExpenseCategory[]
  joinRequests           JoinRequest[]
  wallets                Wallet[]
  ledgerTransactions     LedgerTransaction[]
  approvalRules          WalletApprovalRule[]
  approvalRequests       WalletApprovalRequest[]
  circleApprovalRequests ApprovalRequest[]
  financialReceipts      FinancialReceipt[]
  approvalWorkflows      ApprovalWorkflow[]
  approvalDelegations    ApprovalDelegation[]
  payoutCycles           PayoutCycle[]
  moderationReviews      CircleModerationReview[]
  supportTickets         SupportTicket[]
  feedPosts              FeedPost[]
  events                 CircleEvent[]
  polls                  CirclePoll[]
  verification           CircleVerification?
  reputation             CircleReputation?
  inviteEvents           CircleInviteEvent[]
  investmentAssets       InvestmentAsset[]
  investmentReturns      InvestmentReturn[]
  workflow               CircleWorkflow?
  automationRules        CircleAutomationRule[]
  paymentIntents         CirclePaymentIntent[]
  projects               Project[]
  projectExpenses        ProjectExpense[]
  projectAssets          ProjectAsset[]
  projectRevenues        ProjectRevenue[]
  distributions          ProjectDistribution[]
}

model CircleMember {
  id       String     @id @default(cuid())
  circleId String
  userId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  permissions CircleMemberPermission[]

  @@unique([circleId, userId])
}

model CircleMemberPermission {
  id           String   @id @default(cuid())
  membershipId String
  permission   String
  granted      Boolean
  grantedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  membership CircleMember @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, permission])
  @@index([membershipId])
}

model Contribution {
  id                String             @id @default(cuid())
  circleId          String
  userId            String
  planId            String?
  amount            Decimal            @db.Decimal(12, 2)
  status            ContributionStatus @default(PAID)
  paymentDate       DateTime           @default(now())
  note              String?
  createdById       String
  approvalRequestId String?            @unique
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  circle          Circle            @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user            User              @relation("ContributionPayer", fields: [userId], references: [id])
  plan            ContributionPlan? @relation(fields: [planId], references: [id])
  createdBy       User              @relation("ContributionRecorder", fields: [createdById], references: [id])
  approvalRequest ApprovalRequest?  @relation(fields: [approvalRequestId], references: [id])
  goalAllocations GoalAllocation[]

  @@index([circleId])
  @@index([userId])
  @@index([planId])
  @@index([createdAt])
}

enum ContributionFrequency {
  WEEKLY
  MONTHLY
  ONCE_OFF
  CUSTOM
}

enum ContributionStatus {
  PAID
  PENDING
  PENDING_REVIEW
  CONFIRMED
  REJECTED
  OVERDUE
  CANCELLED
}

enum ApprovalType {
  CONTRIBUTION
  EXPENSE
  SETTLEMENT
  PROJECT
  WALLET_WITHDRAWAL
  WALLET_TRANSFER
  GOAL_WITHDRAWAL
  JOIN_REQUEST
  MEMBER_PROMOTION
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum ApprovalDecision {
  APPROVE
  REJECT
}

model ContributionPlan {
  id          String                @id @default(cuid())
  circleId    String
  name        String
  description String?
  amount      Decimal               @db.Decimal(12, 2)
  frequency   ContributionFrequency @default(MONTHLY)
  dueDay      Int?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean               @default(true)
  deletedAt   DateTime?
  createdById String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  circle        Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("ContributionPlanCreator", fields: [createdById], references: [id])
  contributions Contribution[]

  @@index([circleId])
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

model Goal {
  id            String     @id @default(cuid())
  circleId      String
  name          String
  description   String?
  targetAmount  Decimal    @db.Decimal(12, 2)
  currentAmount Decimal    @default(0) @db.Decimal(12, 2)
  deadline      DateTime?
  deletedAt     DateTime?
  status        GoalStatus @default(ACTIVE)
  createdById   String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  circle      Circle           @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy   User             @relation(fields: [createdById], references: [id])
  allocations GoalAllocation[]

  @@index([circleId])
}

model GoalAllocation {
  id             String    @id @default(cuid())
  circleId       String
  goalId         String
  userId         String
  contributionId String?
  amount         Decimal   @db.Decimal(12, 2)
  note           String?
  allocationDate DateTime  @default(now())
  deletedAt      DateTime?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  circle       Circle        @relation(fields: [circleId], references: [id], onDelete: Cascade)
  goal         Goal          @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user         User          @relation("GoalAllocationReceiver", fields: [userId], references: [id])
  contribution Contribution? @relation(fields: [contributionId], references: [id])
  createdBy    User          @relation("GoalAllocationCreator", fields: [createdById], references: [id])

  @@index([circleId])
  @@index([goalId])
  @@index([userId])
}

enum SplitType {
  EQUAL
  PERCENTAGE
  EXACT
}

model Expense {
  id          String    @id @default(cuid())
  circleId    String
  paidById    String
  createdById String
  title       String
  notes       String?
  amount      Decimal   @db.Decimal(12, 2)
  category    String    @default("other")
  splitType   SplitType @default(EQUAL)
  expenseDate DateTime  @default(now())
  receiptUrl  String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  circle    Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  paidBy    User           @relation("ExpensePayer", fields: [paidById], references: [id])
  createdBy User           @relation("ExpenseCreator", fields: [createdById], references: [id])
  splits    ExpenseSplit[]

  @@index([circleId])
  @@index([createdAt])
}

model ExpenseSplit {
  id         String    @id @default(cuid())
  expenseId  String
  userId     String
  amount     Decimal   @db.Decimal(12, 2)
  percentage Decimal?  @db.Decimal(5, 2)
  settled    Boolean   @default(false)
  settledAt  DateTime?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

model Balance {
  id         String   @id @default(cuid())
  circleId   String
  debtorId   String
  creditorId String
  amount     Decimal  @db.Decimal(12, 2)
  updatedAt  DateTime @updatedAt

  circle   Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  debtor   User   @relation("Debtor", fields: [debtorId], references: [id])
  creditor User   @relation("Creditor", fields: [creditorId], references: [id])

  @@unique([circleId, debtorId, creditorId])
  @@index([circleId])
}

enum SettlementStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

model Settlement {
  id             String           @id @default(cuid())
  circleId       String
  debtorId       String
  creditorId     String
  amount         Decimal          @db.Decimal(12, 2)
  note           String?
  settlementDate DateTime         @default(now())
  status         SettlementStatus @default(PENDING)
  createdById    String
  confirmedById  String?
  confirmedAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  circle      Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  debtor      User   @relation("SettlementDebtor", fields: [debtorId], references: [id])
  creditor    User   @relation("SettlementCreditor", fields: [creditorId], references: [id])
  createdBy   User   @relation("SettlementCreator", fields: [createdById], references: [id])
  confirmedBy User?  @relation("SettlementConfirmer", fields: [confirmedById], references: [id])

  @@index([circleId])
  @@index([debtorId])
  @@index([creditorId])
}

enum TransactionType {
  CONTRIBUTION
  EXPENSE
  SETTLEMENT
  WITHDRAWAL
  GOAL_ALLOCATION
}

model Transaction {
  id            String          @id @default(cuid())
  circleId      String
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  description   String?
  referenceId   String?
  referenceType String?
  initiatedById String
  createdAt     DateTime        @default(now())

  circle      Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  initiatedBy User   @relation(fields: [initiatedById], references: [id])

  @@index([circleId])
  @@index([initiatedById])
}

enum NotificationType {
  INVITATION_RECEIVED
  INVITATION_ACCEPTED
  NEW_MEMBER_JOINED
  CONTRIBUTION_MADE
  CONTRIBUTION_PLAN_CREATED
  CONTRIBUTION_REMINDER
  EXPENSE_ADDED
  SETTLEMENT_REQUESTED
  SETTLEMENT_CONFIRMED
  SETTLEMENT_REJECTED
  GOAL_CREATED
  GOAL_ALLOCATION_ADDED
  GOAL_COMPLETED
  GOAL_DEADLINE_REMINDER
  RECEIPT_ISSUED
  RECEIPT_VOIDED
  RECEIPT_REPLACED
  STATEMENT_READY
  APPROVAL_STAGE_ACTIVATED
  APPROVAL_STAGE_COMPLETED
  APPROVAL_ASSIGNED
  APPROVAL_DELEGATED
  APPROVAL_ESCALATED
  APPROVAL_OVERDUE
  APPROVAL_WORKFLOW_COMPLETED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  circleId  String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user   User    @relation(fields: [userId], references: [id])
  circle Circle? @relation(fields: [circleId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Invitation {
  id          String           @id @default(cuid())
  circleId    String
  email       String
  invitedById String
  status      InvitationStatus @default(PENDING)
  token       String           @unique @default(cuid())
  createdAt   DateTime         @default(now())
  expiresAt   DateTime

  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("Inviter", fields: [invitedById], references: [id])

  @@unique([circleId, email])
}

// ─── Subscription Models ──────────────────────────────────

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  EXPIRED
}

model Plan {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String
  price           Decimal         @db.Decimal(10, 2)
  currency        String          @default("ZAR")
  interval        BillingInterval @default(MONTHLY)
  circleLimit     Int             @default(3)
  memberLimit     Int?
  aiMessageLimit  Int?
  storageLimitMb  Int?
  supportLevel    String?
  apiRequestLimit Int?
  features        Json
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  isArchived      Boolean         @default(false)
  isPublic        Boolean         @default(true)
  trialDays       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  subscriptions       UserSubscription[]
  paymentTransactions PaymentTransaction[]
  planFeatures        PlanFeature[]
}

enum PlanFeatureValueType {
  BOOLEAN
  NUMBER
  STRING
  JSON
}

model PlanFeature {
  id        String               @id @default(cuid())
  planId    String
  key       String
  label     String
  value     Json
  valueType PlanFeatureValueType @default(BOOLEAN)
  isEnabled Boolean              @default(true)
  sortOrder Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
}

model UserSubscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             Plan                 @relation(fields: [planId], references: [id])
  transactions     PaymentTransaction[]
  promoRedemptions PromoRedemption[]

  @@unique([userId])
}

// ─── Payment Models ───────────────────────────────────────

enum PaymentProvider {
  PAYFAST
  OZOW
  STITCH
  PEACH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

model PaymentTransaction {
  id                String          @id @default(cuid())
  userId            String
  subscriptionId    String?
  planId            String
  provider          PaymentProvider
  providerReference String?
  merchantReference String          @unique
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("ZAR")
  status            PaymentStatus   @default(PENDING)
  metadata          Json?
  paidAt            DateTime?
  failedAt          DateTime?
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  plan             Plan              @relation(fields: [planId], references: [id])
  subscription     UserSubscription? @relation(fields: [subscriptionId], references: [id])
  promoRedemptions PromoRedemption[]

  @@index([userId])
  @@index([merchantReference])
}

// ─── Internal Admin ───────────────────────────────────────

enum InternalAdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  FINANCE
}

model InternalAdmin {
  id          String            @id @default(cuid())
  userId      String            @unique
  role        InternalAdminRole @default(ADMIN)
  isActive    Boolean           @default(true)
  permissions Json?
  lastLoginAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Audit Logs ──────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  circleId   String?
  action     String
  entityType String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  circle Circle? @relation("AuditLogCircle", fields: [circleId], references: [id])

  @@index([circleId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Projects ─────────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  FUNDING
  FUNDED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ProjectVisibility {
  PRIVATE
  MEMBERS_ONLY
}

model Project {
  id                   String            @id @default(cuid())
  circleId             String
  createdById          String
  name                 String
  slug                 String
  description          String?
  type                 String            @default("general")
  status               ProjectStatus     @default(DRAFT)
  visibility           ProjectVisibility @default(MEMBERS_ONLY)
  targetAmount         Decimal?          @db.Decimal(12, 2)
