// ─── ApprovalRequestDecision ──────────────────────────
//
// Records a single reviewer's decision on a request.
// For multi-stage workflows, requestStageId scopes the decision to a
// specific stage. For simple (single-stage) approvals, requestStageId
// is null and the decision counts against the top-level minimumApprovals.
//
// Backward compatible: existing single-stage decisions have null for all
// new fields. No existing rows are modified.

model ApprovalRequestDecision {
  id                  String           @id @default(cuid())
  approvalRequestId   String
  requestStageId      String?
  reviewerId          String
  originalReviewerId  String? // The originally assigned reviewer (before delegation)
  delegatedReviewerId String? // The actual reviewer if delegation was used
  decision            ApprovalDecision
  comment             String?
  source              String? // "DIRECT", "DELEGATION", "ESCALATION", "AUTO"
  actedAt             DateTime?
  metadata            Json?
  createdAt           DateTime         @default(now())

  approvalRequest ApprovalRequest       @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  requestStage    ApprovalRequestStage? @relation(fields: [requestStageId], references: [id])
  reviewer        User                  @relation("UnivApprovalReviewer", fields: [reviewerId], references: [id])

  @@unique([approvalRequestId, reviewerId])
}

